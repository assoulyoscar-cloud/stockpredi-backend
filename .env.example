# StockPredi Backend - variables d'environnement
# Copier en .env et remplir avec les vraies valeurs.
# NE JAMAIS committer le fichier .env reel.

FLASK_ENV=production
FLASK_DEBUG=False
PORT=5000

# Supabase (projet Frankfurt EU)
SUPABASE_URL=https://VOTRE-PROJET.supabase.co
SUPABASE_ANON_KEY=votre_cle_anon
SUPABASE_SERVICE_KEY=votre_cle_service_role

# Ollama (recommandations IA - fallback regles metier si indisponible)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Stripe
STRIPE_SECRET_KEY=sk_test_XXXX
STRIPE_PUBLISHABLE_KEY=pk_test_XXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXX
STRIPE_PRICE_ID=price_XXXX

# CORS
FRONTEND_URL=https://stockpredi.vercel.app
